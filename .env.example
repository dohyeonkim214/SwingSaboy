# 이 파일을 .env로 복사하고 값을 채우세요 (.env는 gitignore 대상)

# Google Cloud Console → YouTube Data API v3 사용 설정 후 발급한 API 키
YOUTUBE_API_KEY=

# 백엔드 포트 (기본 3001 — vite.config.js의 프록시 대상과 일치해야 함)
# PORT=3001

# 수집 주기(시간, 기본 24)
# COLLECT_INTERVAL_HOURS=24

# 일일 할당량 사용 상한(유닛, 기본 5000 — 유튜브 무료 한도는 10000)
# DAILY_QUOTA_BUDGET=5000
